{
    # Enable FrankenPHP (embedded PHP in Caddy)
    frankenphp

    # Disable auto TLS since Railway handles HTTPS
    auto_https off
}

# Listen on Railway's default port 8080
:8080 {
    # Laravel serves from the public/ directory
    root * /app/public

    # Compress responses
    encode zstd br gzip

    # Handle PHP files via FrankenPHP's embedded PHP
    php_fastcgi

    # Serve static files
    file_server
}
